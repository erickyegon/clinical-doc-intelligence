# ============================================================
# Clinical Document Intelligence Platform - Environment Config
# ============================================================
# Copy to .env and fill in your API keys.
# The platform works with ANY of these providers (Module 3: Provider Switching)

# === LLM Provider (choose one: openai | groq | bedrock) ===
LLM_PROVIDER=groq

# OpenAI (paid, highest quality)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# Groq (free tier available, fast inference)
GROQ_API_KEY=gsk_your-key-here
GROQ_MODEL=llama-3.1-70b-versatile

# AWS Bedrock (enterprise, requires AWS credentials)
# AWS_REGION=us-east-1
# BEDROCK_MODEL=anthropic.claude-3-sonnet-20240229-v1:0

# === Embeddings ===
# local = all-MiniLM-L6-v2 (free, runs on CPU)
# openai = text-embedding-3-small (paid, higher quality)
EMBEDDING_PROVIDER=local

# === FDA Data ===
# Optional: higher rate limits with an API key (free from openFDA)
# OPENFDA_API_KEY=your-key-here

# === Vector Store ===
CHROMA_COLLECTION=fda_drug_labels

# === Retrieval Tuning ===
RETRIEVAL_TOP_K=10
RERANK_TOP_K=5
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# === Cache (optional, requires Redis) ===
ENABLE_CACHE=false
# REDIS_URL=redis://localhost:6379/0

# === API Server ===
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
ENABLE_TOKEN_TRACKING=true
